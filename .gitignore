# Dependencies
node_modules/

# Build output
dist/

# Backend runtime at repo root stays out of git, but backend source is tracked.
server/*
!server/DiffSingerApi/
!server/DiffSingerApi/**
server/DiffSingerApi/bin/
server/DiffSingerApi/obj/
server/DiffSingerApi/output/
server/DiffSingerApi/uploads/
server/DiffSingerApi/voicebanks/
server/DiffSingerApi/tempdiffsingertest/
server/DiffSingerApi/TestBuild/

# Vendored OpenUtau source subset required by the backend source.
OpenUtau/*
!OpenUtau/OpenUtau.Core/
!OpenUtau/OpenUtau.Core/**
!OpenUtau/OpenUtau.Plugin.Builtin/
!OpenUtau/OpenUtau.Plugin.Builtin/**
OpenUtau/OpenUtau.Core/bin/
OpenUtau/OpenUtau.Core/obj/
OpenUtau/OpenUtau.Core/tempdiffsingertest/
OpenUtau/OpenUtau.Plugin.Builtin/bin/
OpenUtau/OpenUtau.Plugin.Builtin/obj/
OpenUtau/OpenUtau.Plugin.Builtin/tempdiffsingertest/

# External model/runtime trees
external/
$dest/

# SeedVC local service source is tracked, but local runtime data is not
scripts/seedvc_service/__pycache__/
scripts/seedvc_service/checkpoints/
scripts/seedvc_service/runtime/

# Logs
*.log
*.err.log

# Temp files
tmp-*.mid

# Dev tools
.playwright-mcp/
.claude/
.codex-build/
.tools/

# Research & handoff notes
research/
handoff/
backups/

# System files
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp
